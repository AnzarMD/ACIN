# Production: frontend calls its own /api/proxy/* routes (HTTPS→HTTP proxy)
# This avoids mixed content errors.
NEXT_PUBLIC_API_URL=/api/proxy

# Server-side: the proxy route calls the ALB directly (server-to-server, no HTTPS needed)
API_URL=http://acin-alb-1572894229.ap-south-1.elb.amazonaws.com/v1
